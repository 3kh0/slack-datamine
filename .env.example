# Poll source: "cdp" for a logged-in Slack desktop renderer, or "cookie" for
# direct HTML fetches. CDP is the full-fidelity VPS path.
POLL_SOURCE=cdp
CDP_PORT=9222
RELOAD_CDP=1
SNAPSHOT_DIR=queue/html
QUEUE_ONLY=1
INLINE_FOLLOWUP=0
FOLLOWUP_CHECKS=18
FOLLOWUP_INTERVAL=10
WATCH_INTERVAL=1
SNAPSHOT_TIMEOUT=30
FETCH_CLIENT_HTML=1
FETCH_CLIENT_TIMEOUT_MS=5000
CDP_COMMAND_TIMEOUT_MS=10000

# Runtime with global WebSocket support. Node 24+ works.
RUNTIME=node

# REQUIRED for POLL_SOURCE=cookie — your Slack 'd' session cookie (value only, starts with xoxd-).
# Get it: log into Slack in a browser → DevTools → Application → Cookies →
# https://app.slack.com → copy the raw value of the `d` cookie.
# Do not use DevTools' URL-decoded view; keep escapes like %2B, %2F, and %3D.
# This is YOUR account's auth; treat it like a password. The cookie is only used
# to fetch the build manifest HTML; chunk downloads are public.
SLACK_D_COOKIE=xoxd-REPLACE_ME

# manifest host override
CLIENT_URL=https://app.slack.com/client

# set zero to push changes
GIT_PUSH=0

# Optional for unattended signed commits/tags.
GPG_SIGNING_KEY=4DA8B4914D335CE4D6D0C087A1263DC479EDB62F
GPG_PASSPHRASE_FILE=/root/.config/slack-datamine/gpg-passphrase

# Set to 1 only if you are okay mining Slack's public webpack manifest fallback.
# It is incomplete versus authenticated client HTML / CDP and misses high-signal enums.
ALLOW_PARTIAL_MANIFEST=0
